APP_NAME=Laravel
APP_ENV=production
APP_DEBUG=false
APP_URL=https://librarymanagementsystem-a6r5.onrender.com
APP_KEY=base64:REPLACE_WITH_FIXED_APP_KEY

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_URL=
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="CCLMS Library"

# Set MAIL_USERNAME, MAIL_PASSWORD, and MAIL_FROM_ADDRESS in Render.
# Keep MAIL_MAILER=smtp for the live site so password reset emails can be sent.
# If Render provides DATABASE_URL for your PostgreSQL service, Laravel can use that too.
